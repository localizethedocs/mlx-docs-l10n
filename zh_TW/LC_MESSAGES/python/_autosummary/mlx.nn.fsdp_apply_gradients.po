#: ../../../src/python/_autosummary/mlx.nn.fsdp_apply_gradients.rst:2
msgid "mlx.nn.fsdp\\_apply\\_gradients"
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:1
msgid ""
"Perform a distributed optimizer step by sharding gradients and optimizer "
"states across ranks."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:3
msgid ""
"This helper function performs the following steps: 1. Reduce-scatter the "
"gradients across ranks so each rank gets a shard of the averaged gradients. "
"2. Optionally clip the sharded gradients by global norm. 3. Apply the "
"optimizer update on the local parameter slice using the sharded gradients. "
"4. All-gather the updated parameter slices from all ranks to reconstruct the "
"full parameters tree."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:9
msgid "This is similar to PyTorch's FSDP with `reshard_after_forward=False`."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:11
msgid ""
"The Python tree containing the full gradients (it should have the same "
"structure as ``parameters``). Each gradient's first dimension must be "
"divisible by ``fsdp_group.size()``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:15
msgid ""
"The Python tree containing the full parameters (it should have the same "
"structure across processes). Each parameter's first dimension must be "
"divisible by ``fsdp_group.size()``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:19
msgid "Optimizer with an ``apply_gradients`` method."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:20
msgid ""
"The group of processes for FSDP sharding. If ``None``, the global group is "
"used."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:23
msgid ""
"The group of processes for data-parallel gradient averaging. Required when "
"``fsdp_group`` is smaller than the world (e.g. FSDP intra-node, DDP inter-"
"node). Default: ``None``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:28
msgid ""
"Group arrays until their size in bytes exceeds this number. Perform one "
"communication step per group of arrays. If less or equal to 0 array grouping "
"is disabled. Default: ``32MiB``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:32
msgid ""
"The stream to use for the communication. If unspecified the default "
"communication stream is used which can vary by back-end. Default: ``None``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:36
msgid ""
"If provided, clip gradients to this maximum global norm before applying the "
"optimizer update. Default: ``None``."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:0
msgid "Returns"
msgstr "回傳"

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:41
msgid ""
"If ``max_norm`` is ``None``, returns the updated full-parameter tree. "
"Otherwise returns ``(parameters, grad_norm)``, where ``grad_norm`` is the "
"global gradient norm before clipping."
msgstr ""

#: ../../../../../../.conda/lib/python3.12/site-packages/mlx/nn/utils.py:docstring
#: of mlx.nn.utils.fsdp_apply_gradients:46
msgid "Example"
msgstr "範例"
